DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

LPAGENT_API_KEY=
LPAGENT_API_BASE_URL=https://api.lpagent.io/open-api/v1

DATABASE_URL=postgresql://lpagent:lpagent@localhost:5432/lpagent_discord?schema=public

ALERT_CRON=*/5 * * * *
